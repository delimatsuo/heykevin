    "Tap to stop": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca para detener"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque para parar"
          }
        }
      }
    },
    "Tapping a button opens your phone dialer with a carrier code. Tap Call to confirm. To verify status, dial *#21# from your keypad.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al tocar un botón se abre el marcador con un código de operador. Toca Llamar para confirmar. Para verificar el estado, marca *#21# desde tu teclado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao tocar em um botão, o discador abre com um código da operadora. Toque em Ligar para confirmar. Para verificar o status, disque *#21# no teclado."
          }
        }
      }
    },
    "Tell Kevin about your business so he can answer questions": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuéntale a Kevin sobre tu negocio para que pueda responder preguntas"
